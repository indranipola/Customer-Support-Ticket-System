<Window x:Class="TicketSystemDesktop.Views.TicketListView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tickets" Height="400" Width="700">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="ticketGrid" AutoGenerateColumns="False">

            <DataGrid.Columns>

                <DataGridTextColumn Header="Ticket Number" Binding="{Binding TicketNumber}" Width="120"/>
                <DataGridTextColumn Header="Subject" Binding="{Binding Subject}" Width="150"/>
                <DataGridTextColumn Header="Priority" Binding="{Binding Priority}" Width="100"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                <DataGridTextColumn Header="Created Date" Binding="{Binding CreatedDate}" Width="150"/>

            </DataGrid.Columns>

        </DataGrid>

        <Button Grid.Row="1"
                Content="Refresh"
                Width="120"
                HorizontalAlignment="Right"
                Click="Refresh_Click"/>

    </Grid>

</Window>
